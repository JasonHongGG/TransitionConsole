# ----------------------------------------
# Service Ports
# ----------------------------------------
# 開多份專案時可直接設定整組平移量，例如 0 / 100 / 200
PORT_OFFSET=0
MAIN_SERVER_PORT=7070
AI_SERVER_PORT=7081
OPERATOR_SERVER_PORT=7082

# ----------------------------------------
# AI Runtime / Provider
# ----------------------------------------
AI_PROVIDER=copilot-sdk
GITHUB_TOKEN=your_github_token_here
AI_RUNTIME_MODEL=gpt-5.2
AI_RUNTIME_TIMEOUT_MS=300000
AI_RUNTIME_CLI_PATH=
AI_RUNTIME_CLI_URL=
AI_RUNTIME_PROFILE=true

# ----------------------------------------
# Path Planner
# ----------------------------------------
# llm | mock-replay
PATH_PLANNER_PROVIDER=llm
# implementation | exp1_baseline | exp2_coverage_first | exp3_new_feature_first
# exp4_long_path_first | exp5_scenario_first | exp6_risk_first
# exp7_new_feature_long_path | exp8_new_feature_scenario | exp9_new_feature_risk
# exp10_long_path_scenario | exp11_long_path_risk | exp12_scenario_risk
# exp13_new_feature_long_path_scenario | exp14_new_feature_long_path_risk
# exp15_new_feature_scenario_risk | exp16_long_path_scenario_risk | exp17_all_priorities
# 也可用簡寫：default / 1 ~ 17 / baseline / coverage / new_feature / long_path / scenario / risk / all
PATH_PLANNER_PROMPT_VARIANT=implementation
PATH_PLANNER_TIMEOUT_MS=300000
PATH_PLANNER_MOCK_DIR=mock-data/path-planner
PATH_PLANNER_MOCK_LOOP=true

# ----------------------------------------
# Planned Runner - Feature Toggles
# ----------------------------------------
# agent | pass-only (完全不跑 Executor，直接 pass，用來只測試 Path Planner)
PLANNED_RUNNER_EXECUTOR_MODE=pass-only
PLANNED_RUNNER_REAL_BROWSER=false
PLANNED_RUNNER_HIGHLIGHT_MOUSE=false
OPERATOR_BROWSER_HEADLESS=true

# ----------------------------------------
# Step Narrator
# ----------------------------------------
# llm | mock-replay
STEP_NARRATOR_PROVIDER=llm
# agent | input (Step 的口述指令以及 Validation 是由 LLM 生成，還是由使用者輸入的 json)
STEP_NARRATOR_MODE=input
STEP_NARRATOR_MODEL=
STEP_NARRATOR_TIMEOUT_MS=300000
STEP_NARRATOR_MOCK_DIR=mock-data/step-narrator
STEP_NARRATOR_MOCK_LOOP=true

# ----------------------------------------
# Operator Loop
# ----------------------------------------
# llm | mock-replay
OPERATOR_LOOP_PROVIDER=llm
OPERATOR_LOOP_MODEL=
OPERATOR_LOOP_TIMEOUT_MS=300000
OPERATOR_LOOP_MOCK_DIR=mock-data/operator-loop
OPERATOR_LOOP_MOCK_LOOP=true
OPERATOR_LOOP_MAX_HISTORY_TURNS=12

# 控制 runtime screenshot 的根目錄。
OPERATOR_RUNTIME_SCREENSHOT_LOG_ROOT=logs/runtime
# 控制第三層 step 資料夾名稱中 narrative.summary 的最大長度
OPERATOR_RUNTIME_SCREENSHOT_STEP_SUMMARY_MAX_LEN=90
